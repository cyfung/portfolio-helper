<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Widget card background -->
    <color name="widget_bg">#1C1B1F</color>

    <!-- Generic text colors (used by layout defaults and drawables) -->
    <color name="widget_text_primary">#E6E1E5</color>
    <color name="widget_text_muted">#938F99</color>
    <color name="widget_positive">#4CAF50</color>

    <!-- Card background colors -->
    <!-- muted slate blue -->
    <color name="widget_state_checking">#7A94B0</color>
    <!-- muted sage green -->
    <color name="widget_state_ok">#B5CCB8</color>
    <!-- muted dusty rose -->
    <color name="widget_state_failed">#D9A8A8</color>
    <!-- muted warm amber -->
    <color name="widget_state_alert">#E8D4A0</color>

    <!-- Text on checking card (white on slate blue) -->
    <color name="widget_text_on_colored">#FFFFFF</color>
    <color name="widget_text_on_colored_muted">#CCFFFFFF</color>

    <!-- Text on OK/healthy card -->
    <color name="widget_text_on_ok">#2D4A31</color>
    <color name="widget_text_on_ok_muted">#3D5E41</color>

    <!-- Text on failed card -->
    <color name="widget_text_on_failed">#5C1F1F</color>
    <color name="widget_text_on_failed_muted">#7A3030</color>

    <!-- Text on alert card -->
    <color name="widget_text_on_alert">#5C3D00</color>
    <color name="widget_text_on_alert_muted">#7A5200</color>

    <!-- muted warm amber-beige — for ok state that hasn't refreshed recently -->
    <color name="widget_state_stale">#D4B896</color>
    <!-- Text on stale card -->
    <color name="widget_text_on_stale">#4A3200</color>
    <color name="widget_text_on_stale_muted">#6B4800</color>

    <!-- muted powder blue -->
    <color name="widget_state_suggestion">#B8CDE8</color>
    <!-- Text on suggestion card -->
    <color name="widget_text_on_suggestion">#1E3555</color>
    <color name="widget_text_on_suggestion_muted">#2E4A6B</color>
</resources>
