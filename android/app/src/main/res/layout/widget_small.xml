<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/widget_bg_rounded"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- Icon circle: 44dp fills height nicely within 80dp card -->
    <ImageView
        android:id="@+id/icon_state"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/ic_widget_sync"
        android:background="@drawable/widget_icon_bg"
        android:padding="10dp"
        android:scaleType="fitCenter" />

    <!-- Title + subtitle -->
    <LinearLayout
        android:id="@+id/container_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/text_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/widget_text_primary" />

        <TextView
            android:id="@+id/text_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:maxLines="4"
            android:ellipsize="end"
            android:layout_marginTop="3dp"
            android:textColor="@color/widget_text_muted" />


        <Chronometer
            android:id="@+id/chronometer_elapsed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textSize="16sp"
            android:textColor="@color/widget_text_muted" />

    </LinearLayout>


</LinearLayout>
