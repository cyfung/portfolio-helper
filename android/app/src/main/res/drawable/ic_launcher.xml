<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="1000"
    android:viewportHeight="1000">

    <!-- Background white with rounded corners -->
    <path
        android:pathData="M100,0 L900,0 A100,100 0 0 1 1000,100 L1000,900 A100,100 0 0 1 900,1000 L100,1000 A100,100 0 0 1 0,900 L0,100 A100,100 0 0 1 100,0 Z"
        android:fillColor="#FFFFFF" />

    <!-- Area fill with Gradient -->
    <path
        android:pathData="M116,786 L116,626 L276,498 L404,562 L564,338 L724,402 L884,242 L884,786 Z">
        <fill android:type="linear"
              android:startX="500" android:startY="242"
              android:endX="500" android:endY="786">
            <item android:offset="0" android:color="#331A56FF" /> <!-- 0.2 opacity -->
            <item android:offset="1" android:color="#001A56FF" /> <!-- 0 opacity -->
        </fill>
    </path>

    <!-- Chart line -->
    <path
        android:pathData="M116,626 L276,498 L404,562 L564,338 L724,402 L884,242"
        android:strokeColor="#1A56FF"
        android:strokeWidth="48"
        android:strokeLineJoin="round"
        android:strokeLineCap="round" />

    <!-- Dots -->
    <!-- First dot (white fill, blue stroke) -->
    <path
        android:pathData="M564,338m-56,0a56,56 0 1,1 112,0a56,56 0 1,1 -112,0"
        android:fillColor="#FFFFFF"
        android:strokeColor="#1A56FF"
        android:strokeWidth="40" />

    <!-- Second dot (solid blue) -->
    <path
        android:pathData="M884,242m-56,0a56,56 0 1,1 112,0a56,56 0 1,1 -112,0"
        android:fillColor="#1A56FF" />

    <!-- Bottom axis -->
    <path
        android:pathData="M116,850 L884,850"
        android:strokeColor="#1A56FF"
        android:strokeWidth="24"
        android:fillAlpha="0.25" />

    <!-- Tick marks -->
    <path
        android:pathData="M276,850 L276,898 M564,850 L564,898 M884,850 L884,898"
        android:strokeColor="#1A56FF"
        android:strokeWidth="24"
        android:fillAlpha="0.4" />

</vector>
